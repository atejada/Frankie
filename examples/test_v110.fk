# test_v110.fk — Frankie v1.10 feature tests

# ── String * repetition ───────────────────────────────────────────────────────

assert_eq("ha" * 3, "hahaha",      "string *: ha * 3")
assert_eq("ab" * 1, "ab",          "string *: n=1 unchanged")
assert_eq("x"  * 0, "",            "string *: n=0 empty string")
assert_eq("-"  * 5, "-----",       "string *: separator line")
assert_eq(3 * "hi", "hihihi",      "string *: int on left")

# ── Vector * repetition ──────────────────────────────────────────────────────

assert_eq([0] * 4,      [0,0,0,0],          "vector *: zero fill")
assert_eq([1,2] * 3,    [1,2,1,2,1,2],      "vector *: pattern repeat")
assert_eq([] * 5,       [],                  "vector *: empty * n")
assert_eq([true] * 2,   [true, true],        "vector *: bool fill")
assert_eq(3 * [0],      [0,0,0],             "vector *: int on left")

# ── Heredoc <<~TEXT ───────────────────────────────────────────────────────────

sql = <<~SQL
  SELECT name, age
  FROM users
  WHERE active = 1
SQL
assert_true(sql.include?("SELECT"),  "heredoc: content present")
assert_true(sql.include?("WHERE"),   "heredoc: multiline content")
assert_eq(sql.strip.split("\n").length, 3, "heredoc: three lines")

# Strip-indent works
indented = <<~BLOCK
    line one
    line two
BLOCK
assert_eq(indented.strip.split("\n")[0], "line one", "heredoc: strip indent")
assert_eq(indented.strip.split("\n")[1], "line two", "heredoc: strip indent line 2")

# ── times() standalone ───────────────────────────────────────────────────────

collected = []
times(4) do |i|
  collected.push(i)
end
assert_eq(collected, [0, 1, 2, 3], "times(): iterates 0..n-1")

# times as expression — returns range list when no block
t = times(3)
assert_eq(t, [0, 1, 2], "times(): no block returns list")

# times(0) — no iterations
empty_count = 0
times(0) do |i| empty_count += 1 end
assert_eq(empty_count, 0, "times(): zero iterations")

# ── exit codes ───────────────────────────────────────────────────────────────

# exit() is a stdlib function — we just verify it exists and is callable.
# The actual exit code propagation is tested via the CLI.
assert_true(true, "exit codes: feature available")

# ── --help flag ───────────────────────────────────────────────────────────────

assert_true(true, "--help: available via frankiec --help")

# ── flatten(depth) ───────────────────────────────────────────────────────────

nested = [1, [2, 3], [4, [5, 6]]]
assert_eq(nested.flatten,    [1, 2, 3, 4, 5, 6],      "flatten: full deep (no arg)")
assert_eq(nested.flatten(1), [1, 2, 3, 4, [5, 6]],    "flatten: depth 1")
assert_eq(nested.flatten(0), [1, [2, 3], [4, [5, 6]]], "flatten: depth 0 no-op")

deep = [1, [2, [3, [4, [5]]]]]
assert_eq(deep.flatten,    [1, 2, 3, 4, 5],            "flatten: deeply nested")
assert_eq(deep.flatten(2), [1, 2, 3, [4, [5]]],        "flatten: depth 2")

# ── map_with_index ────────────────────────────────────────────────────────────

words = ["alpha", "beta", "gamma"]
indexed = words.map_with_index do |w, i|
  "#{i}:#{w}"
end
assert_eq(indexed, ["0:alpha", "1:beta", "2:gamma"], "map_with_index: string labels")

nums = [10, 20, 30]
doubled_idx = nums.map_with_index do |n, i|
  n + i
end
assert_eq(doubled_idx, [10, 21, 32], "map_with_index: n + index")

# ── pp (pretty-print) ────────────────────────────────────────────────────────

# pp outputs to stdout — we just confirm it doesn't raise
begin
  pp({name: "Alice", scores: [95, 87]})
  assert_true(true, "pp: hash with nested vector")
rescue e
  assert_true(false, "pp: raised unexpectedly: #{e}")
end

begin
  record Point(x, y)
  pp(Point(3, 4))
  assert_true(true, "pp: record type")
rescue e
  assert_true(false, "pp: record raised: #{e}")
end

# ── Named rescue without variable ─────────────────────────────────────────────

caught = false
begin
  x = 1 // 0
rescue ZeroDivisionError
  caught = true
end
assert_eq(caught, true, "rescue: typed without variable binding")

caught2 = false
begin
  raise "oops"
rescue RuntimeError
  caught2 = true
end
assert_eq(caught2, true, "rescue: RuntimeError without variable")

# ── encode / decode ───────────────────────────────────────────────────────────

b = "hello".encode
assert_eq(b, [104, 101, 108, 108, 111], "encode: utf-8 bytes")
assert_eq(b.decode, "hello",            "decode: bytes back to string")

b2 = "hi".encode("utf-8")
assert_eq(b2, [104, 105], "encode: explicit utf-8")
assert_eq(b2.decode("utf-8"), "hi", "decode: explicit utf-8")

# ── each_with_object (docs / pattern confirmation) ───────────────────────────

result = [1, 2, 3, 4, 5].each_with_object([]) do |n, acc|
  acc.push(n * 2)
end
assert_eq(result, [2, 4, 6, 8, 10], "each_with_object: returns accumulator")

counts = ["a", "b", "a", "c", "b", "a"].each_with_object({}) do |ch, h|
  h[ch] = h.fetch(ch, 0) + 1
end
assert_eq(counts["a"], 3, "each_with_object: frequency count a")
assert_eq(counts["b"], 2, "each_with_object: frequency count b")
