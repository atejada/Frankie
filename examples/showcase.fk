puts "── 30. String .format(hash) (v1.11) ──"

puts "Hello, {name}! You are {age}.".format({name: "Alice", age: 30})

tmpl = "{item} x{qty} — ${price}"
puts tmpl.format({item: "Coffee", qty: 2, price: "4.50"})

people = [
  {name: "Alice", role: "Engineer"},
  {name: "Bob",   role: "Designer"}
]
people.each do |p|
  puts "{name} is a {role}.".format(p)
