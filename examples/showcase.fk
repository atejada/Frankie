# showcase.fk — Everything Frankie can do in one program

puts "╔══════════════════════════════════════╗"
puts "║     Frankie v1.0 — Full Showcase     ║"
puts "╚══════════════════════════════════════╝"
puts ""

# ── 1. Error Handling ──────────────────────────────────────────────
puts "── 1. Error Handling (begin/rescue/ensure) ──"

begin
  raise "something broke"
rescue e
  puts "Rescued: #{e}"
ensure
  puts "Ensure block always runs"
end

def safe_sqrt(n)
  begin
    if n < 0
      raise "Cannot sqrt a negative number: #{n}"
    end
    return sqrt(n)
  rescue e
    puts "Error: #{e}"
    return nil
  end
end

puts safe_sqrt(9)
puts safe_sqrt(-4)
puts ""

# ── 2. Regex ───────────────────────────────────────────────────────
puts "── 2. Regex ──"

log = "ERROR 2025-03-14: disk full. WARNING 2025-03-15: low memory."

puts matches(log, "ERROR")
puts match_all(log, "[0-9]{4}-[0-9]{2}-[0-9]{2}")
puts gsub(log, "WARNING", "WARN")
puts "hello" =~ "ell"
puts ""

# ── 3. File I/O ────────────────────────────────────────────────────
puts "── 3. File I/O ──"

file_write("/tmp/fk_showcase.txt", "Frankie\nRuby\nPython\nR\nFortran\n")
lines = file_lines("/tmp/fk_showcase.txt")
puts "Lines: #{length(lines)}"
lines.each do |line|
  puts "  #{line}"
end
file_append("/tmp/fk_showcase.txt", "Frankie is alive!\n")
puts "After append: #{length(file_lines("/tmp/fk_showcase.txt"))} lines"
file_delete("/tmp/fk_showcase.txt")
puts "Deleted: #{file_exists("/tmp/fk_showcase.txt")}"
puts ""

# ── 4. Named Arguments ─────────────────────────────────────────────
puts "── 4. Named Arguments ──"

puts paste("Designed", "by", "Claude", sep: " ")
puts paste("2025", "03", "14", sep: "-")
puts sprintf("%-10s %5d %8.2f", "Frankie", 1, 3.14)
puts ""

# ── 5. String Slicing ──────────────────────────────────────────────
puts "── 5. String & Vector Slicing ──"

s = "Frankenstein"
puts s[0..6]
puts s[7..11]
puts s[-5..-1]

v = [10, 20, 30, 40, 50, 60, 70]
puts v[1..4]
puts v[-3..-1]
puts ""

# ── 6. Nil-safe Hash Access ────────────────────────────────────────
puts "── 6. Nil-safe Hash Access ──"

config = {host: "localhost", port: 5432}
puts config[:host]
puts config[:port]
puts config[:password]
puts config[:timeout]

unless config[:password] != nil
  puts "No password configured (safe default)"
end
puts ""

# ── 7. All Together: a mini log analyser ──────────────────────────
puts "── 7. Mini Log Analyser ──"

logs = [
  "INFO  app started",
  "DEBUG loading config",
  "ERROR disk full",
  "INFO  request received",
  "ERROR connection timeout",
  "WARN  high memory usage",
  "INFO  request complete"
]

counts = {INFO: 0, ERROR: 0, WARN: 0, DEBUG: 0}

logs.each do |line|
  if matches(line, "^INFO")
    counts[:INFO] = counts[:INFO] + 1
  elsif matches(line, "^ERROR")
    counts[:ERROR] = counts[:ERROR] + 1
  elsif matches(line, "^WARN")
    counts[:WARN] = counts[:WARN] + 1
  elsif matches(line, "^DEBUG")
    counts[:DEBUG] = counts[:DEBUG] + 1
  end
end

counts.each do |level, n|
  puts sprintf("  %-6s %d", level, n)
end

errors = logs.map do |line|
  line
end

actual_errors = []
logs.each do |line|
  actual_errors.push(line) if matches(line, "^ERROR")
end
puts "Error lines:"
actual_errors.each do |e|
  puts "  → #{e}"
end

puts ""
puts "Frankie is alive and kicking! 🧟⚡"
