# ── 19. each_slice & each_cons (v1.8) ──────────────────────────────────────
puts ""
puts "── 19. each_slice & each_cons (v1.8) ──"

[1,2,3,4,5,6,7,8,9].each_slice(3) do |s|
  puts s
end

