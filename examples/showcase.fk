# ── 31. .zip_with (v1.11) ────────────────────────────────────────────────────
puts ""
puts "── 31. .zip_with (v1.11) ──"

a = [1, 2, 3, 4, 5]
b = [10, 20, 30, 40, 50]

puts a.zip_with(b) do |x, y| x + y end     # [11, 22, 33, 44, 55]
puts a.zip_with(b) do |x, y| x * y end     # [10, 40, 90, 160, 250]

names  = ["Alice", "Bob", "Carol"]
scores = [95, 87, 92]
rows = names.zip_with(scores) do |n, s| "#{n}: #{s}" end
rows.each do |r| puts r end

# ── 32. Multiple Return Values (v1.11) ──────────────────────────────────────
puts ""
puts "── 32. Multiple Return Values (v1.11) ──"

def minmax(v)
  [min(v), max(v)]
end

def stats(v)
  [mean(v), median(v), stdev(v)]
end

data = [3, 1, 4, 1, 5, 9, 2, 6, 5, 3]

lo, hi = minmax(data)
puts "min=#{lo}, max=#{hi}"

avg, med, sd = stats(data)
puts "mean=#{avg}"
puts "median=#{med}"
puts "stdev=#{sd}"

puts ""
puts "Frankie v1.11 is alive and kicking! 🧟⚡"
