# ── 27. Implicit Return (v1.11) ─────────────────────────────────────────────
puts ""
puts "── 27. Implicit Return (v1.11) ──"

def double(x)
  x * 2
end

def greet(name)
  "Hello, #{name}!"
end

def max_of(a, b)
  if a > b
    a
  else
    b
  end
end

def safe_div(a, b)
  return "division by zero" if b == 0
  a / b
end

puts double(7)            # 14
puts greet("Frankie")     # Hello, Frankie!
puts max_of(3, 9)         # 9
puts safe_div(10, 2)      # 5.0
puts safe_div(10, 0)      # division by zero

# ── 28. Inline if Expression (v1.11) ────────────────────────────────────────
puts ""
puts "── 28. Inline if Expression (v1.11) ──"

x = 7
label = if x > 5 then "big" else "small" end
puts label    # big

score = 95
grade = if score >= 90 then "A" elsif score >= 80 then "B" else "C" end
puts grade    # A

# if-expression in function argument
puts if 3 > 2 then "three beats two" else "math is broken" end

