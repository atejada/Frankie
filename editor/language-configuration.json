{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{",   "close": "}"  },
    { "open": "[",   "close": "]"  },
    { "open": "(",   "close": ")"  },
    { "open": "\"",  "close": "\"", "notIn": ["string"] },
    { "open": "'",   "close": "'",  "notIn": ["string"] },
    { "open": "\"\"\"", "close": "\"\"\"" },
    { "open": "'''", "close": "'''" }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "onEnterRules": [
    {
      "beforeText": "\\b(def|if|elsif|else|unless|while|until|for|do|begin|rescue|ensure|case|when)\\b.*$",
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "^\\s*end\\s*$",
      "action": { "indent": "outdent" }
    }
  ],
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*[?!]?"
}
